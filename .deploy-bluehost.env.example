# Copy to .deploy-bluehost.env (gitignored) and fill in values from Bluehost cPanel → SSH Access.

# cPanel SSH username (shown on the SSH Access page)
BLUEHOST_USER=your_cpanel_username

# SSH host alias from ~/.ssh/config (or override host directly)
BLUEHOST_SSH=actskids-bluehost
BLUEHOST_HOST=74.220.192.137

# Document roots on the server
# staging.actskids.org → /home4/actskids/public_html/staging
# actskids.org (future) → /home4/actskids/public_html/prod
# temp site host       → /home4/actskids/public_html/website_6599f264
BLUEHOST_STAGING_DIR=/home4/actskids/public_html/staging
BLUEHOST_PROD_DIR=/home4/actskids/public_html/prod

# Legacy alias (optional): used as staging fallback if BLUEHOST_STAGING_DIR is unset
# BLUEHOST_REMOTE_DIR=/home4/actskids/public_html/staging

# Public URLs (for docs / smoke checks)
BLUEHOST_STAGING_URL=https://staging.actskids.org
BLUEHOST_PROD_URL=https://actskids.org
BLUEHOST_TEMP_URL=https://website-6599f264.lid.ydn.mybluehost.me
